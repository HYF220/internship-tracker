# ==================== 环境变量配置 ====================
# 复制此文件为 .env，按你的环境修改

# 数据库连接地址
# ============================================================
# 推荐使用 Neon（免费云 PostgreSQL），无需本地安装数据库：
#   1. 注册 https://neon.tech（免费）
#   2. 创建项目，复制 Connection string
#   3. 粘贴到下方 DATABASE_URL=
#   格式：postgresql://用户名:密码@主机/数据库名?sslmode=require
#   注意：Neon 连接字符串末尾的 ?sslmode=require 不要删掉！
# ============================================================
# 如果你有本地 PostgreSQL，也可以用本地地址：
#   postgresql://postgres@localhost:5432/internship_tracker
# ============================================================
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT 签名密钥（必须修改！不要用默认值！）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-random-secret-key
