# ==================== 环境变量配置 ====================
# 复制此文件为 .env，按你的环境修改

# 数据库连接地址
# 本地开发：postgresql://postgres@localhost:5433/internship_tracker
# Docker部署：postgresql://postgres:postgres@postgres:5432/internship_tracker
DATABASE_URL=postgresql://postgres@localhost:5432/internship_tracker

# JWT 签名密钥（生产环境务必修改为随机字符串）
SECRET_KEY=change-this-to-a-random-secret-key-in-production
